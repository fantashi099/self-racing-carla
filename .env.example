# Copy to .env and edit. .env is gitignored (never committed).
# Loaded by python-dotenv at startup of bridge.py and scripts/integration_race.py.

# CARLA server (RPC). Same machine = localhost; else set to the CARLA host.
CARLA_HOST=localhost
CARLA_PORT=2000

# Bridge HTTP server (bridge.py)
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8000

# Race mode
# Comma-separated map basenames to drop from the random pool, e.g. Town10HD_Opt,Town12
RACE_EXCLUDE_MAPS=

# Race parameters (see carla_race.config)
RACE_NUM_CARS=10        # total cars incl. player; >=2
RACE_NUM_LAPS=3         # laps to finish; >=1
RACE_NUM_WALKERS=20     # pedestrians to spawn; >=0
RACE_AI_DIFFICULTY=normal  # easy | normal | hard
